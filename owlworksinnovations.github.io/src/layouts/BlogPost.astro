---
import { Image } from 'astro:assets';
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import RetroPanel from '../components/RetroPanel.astro';

type Props = CollectionEntry<'blog'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, heroImage, id } = Astro.props;
const panelTitle = `FILE_ENTRY_${id?.toUpperCase() || 'DATA'}`;
---

<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		<style>
			.prose {
				color: var(--ps1-white);
				font-family: 'VT323', monospace;
				font-size: 1.6rem;
			}
			.title-section {
				margin-bottom: 2rem;
				border-bottom: 4px solid var(--ps1-grey);
				padding-bottom: 1rem;
			}
			.title-section h1 {
				margin: 0;
				font-size: 1.8rem;
				color: var(--ps1-yellow);
			}
			.date {
				color: var(--ps1-grey);
				font-size: 1.1rem;
				margin-bottom: 1rem;
			}
			.hero-image {
				width: 100%;
				margin-bottom: 2rem;
				border: 4px solid var(--ps1-black);
			}
			:global(.prose h2) { color: var(--ps1-teal); font-size: 1.4rem; margin-top: 2rem; }
			:global(.prose p) { margin-bottom: 1.5rem; }
			:global(.prose code) { background: var(--ps1-black); color: var(--ps1-teal); padding: 0.2rem 0.5rem; }
		</style>
	</head>

	<body>
		<Header />
		<main>
			<article>
				<RetroPanel title={panelTitle} color="teal">
					<div class="title-section">
						<div class="date">
							[ LOG_DATE: <FormattedDate date={pubDate} /> ]
							{
								updatedDate && (
									<div class="last-updated-on">
										REVISION: <FormattedDate date={updatedDate} />
									</div>
								)
							}
						</div>
						<h1>{title.toUpperCase()}</h1>
					</div>
					{heroImage && (
						<Image width={1020} height={510} src={heroImage} alt="" class="hero-image" />
					)}
					<div class="prose">
						<slot />
					</div>
				</RetroPanel>
			</article>
		</main>
		<Footer />
	</body>
</html>
