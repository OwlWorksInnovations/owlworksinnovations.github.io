---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<div class="logo">
			<h2><a href="/">{SITE_TITLE}</a></h2>
		</div>
		<div class="internal-links">
			<HeaderLink href="/">MENU</HeaderLink>
			<HeaderLink href="/#about">INFO</HeaderLink>
			<HeaderLink href="/#skills">DATA</HeaderLink>
			<HeaderLink href="/#projects">SAVE</HeaderLink>
			<HeaderLink href="/#contact">CHAT</HeaderLink>
			<HeaderLink href="/blog">BLOG</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 1rem;
		background: var(--ps1-black);
		border-bottom: 6px solid var(--ps1-grey);
		position: sticky;
		top: 0;
		z-index: 100;
	}
	h2 {
		margin: 0;
		font-size: 1.2rem;
		text-shadow: none;
	}

	h2 a {
		text-decoration: none;
		color: var(--ps1-white);
	}
	nav {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 1.5rem;
		max-width: 1200px;
		margin: 0 auto;
	}
	.internal-links {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
	}
	.internal-links :global(a) {
		padding: 0.75rem 1.5rem;
		background: var(--bg-secondary);
		border: 4px solid var(--border);
		color: var(--ps1-white) !important;
		font-family: 'Press Start 2P', cursive;
		font-size: 0.7rem;
		text-decoration: none;
		box-shadow: 4px 4px 0px rgba(0, 0, 0, 0.5);
		transition: transform 0.1s ease;
	}
	.internal-links :global(a:hover) {
		transform: translate(-2px, -2px);
		box-shadow: 6px 6px 0px rgba(0, 0, 0, 0.5);
		background: var(--ps1-teal);
		color: var(--ps1-black) !important;
	}
	.internal-links :global(a.active) {
		background: var(--ps1-yellow);
		color: var(--ps1-black) !important;
		border-color: var(--ps1-white);
	}
	@media (min-width: 720px) {
		nav {
			flex-direction: row;
			justify-content: space-between;
		}
	}
</style>
