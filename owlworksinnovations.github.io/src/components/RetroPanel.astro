---
const { title = "PANEL_001", color = "teal" } = Astro.props;
---

<div class={`retro-panel ${color}`}>
	<div class="panel-header">
		<span class="header-text">{title}</span>
	</div>
	<div class="panel-body">
		<slot />
	</div>
</div>

<style>
	.retro-panel {
		background: var(--bg-secondary);
		border: 6px solid var(--border);
		box-shadow: 8px 8px 0px rgba(0, 0, 0, 0.6);
		margin-bottom: 3rem;
		position: relative;
	}

	.panel-header {
		background: var(--ps1-grey);
		padding: 0.5rem 1rem;
		border-bottom: 6px solid var(--border);
		display: flex;
		align-items: center;
	}

	.header-text {
		font-family: 'Press Start 2P', cursive;
		font-size: 0.75rem;
		color: var(--ps1-black);
		text-transform: uppercase;
	}

	.panel-body {
		padding: 2rem;
		border-top: 2px solid rgba(255, 255, 255, 0.1);
	}

	/* Color Variants */
	.teal .panel-header { background: var(--ps1-teal); }
	.red .panel-header { background: var(--ps1-red); }
	.yellow .panel-header { background: var(--ps1-yellow); color: var(--ps1-black); }
	.blue .panel-header { background: var(--ps1-blue); }

	.retro-panel::after {
		content: "";
		position: absolute;
		top: -3px; left: -3px; right: -3px; bottom: -3px;
		border: 1px solid rgba(255, 255, 255, 0.2);
		pointer-events: none;
	}
</style>
